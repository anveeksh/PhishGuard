{
  "manifest_version": 3,
  "name": "PhishGuard AI",
  "version": "2.0",
  "description": "AI-powered real-time phishing detection and browser protection",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["gmail_scanner.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["login_detector.js"],
      "run_at": "document_idle"
    }
  ]
}